
--Check if the customer_id is unique or not-
SELECT 
COUNT(Customer_id),
COUNT(DISTINCT Customer_id) 
FROM dbo.customers;

SELECT
Customer_id,
COUNT(Customer_id) countid
FROM dbo.customers 
GROUP BY Customer_id
HAVING COUNT(Customer_id) > 1;

--Check If first_name and last_name has any trailing space or leading space--
SELECT 
LEN(first_name) Lengthfirstname,
LEN(TRIM(first_name)) cleanfirstname,
LEN(last_name) Lengthlastname,
LEN(TRIM(last_name)) Cleanlastname
FROM dbo.customers
WHERE LEN(first_name) != LEN(TRIM(first_name)) AND LEN(last_name) != LEN(TRIM(last_name));

--Check if there is any email id missing--
SELECT 
email
FROM dbo.customers
WHERE email IS NULL;

--Check how many different states we have customers from --
SELECT 
DISTINCT(state) AS Uniquestate,
COUNT(*) AS customer_count
FROM dbo.customers
GROUP BY state;

SELECT * FROM dbo.order_items;
--Check the uniqueness of the order_id--
SELECT 
order_id,
COUNT(order_id) Orderidcount
FROM dbo.order_items
GROUP BY order_id
HAVING item_id >1

--Check the uniqueness of item_id--
SELECT 
item_id,
COUNT(item_id) itemidcount
FROM dbo.order_items
GROUP BY item_id
HAVING COUNT(item_id) >1;

WITH CTE_Duplicate AS
(
SELECT
order_id,
item_id,
ROW_NUMBER() OVER(PARTITION BY order_id ORDER BY (SELECT NULL)) AS ROWNUM
FROM dbo.order_items
) 
SELECT * FROM CTE_Duplicate WHERE ROWNUM >1

--checking for composite Primary key with the addition of order_id and item_id--
SELECT
order_id,
item_id,
COUNT(*) As duplicatecount
FROM order_items
GROUP BY order_id, item_id
HAVING COUNT(*) > 1

--Adding composite Primary key in Order_items table--
ALTER TABLE order_items
ADD CONSTRAINT PK_order_items 
PRIMARY KEY (order_id, item_id);

