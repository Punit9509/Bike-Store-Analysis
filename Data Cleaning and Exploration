--Check for the uniqueness of order id in order table--
SELECT
COUNT(order_id) cnt,
COUNT(DISTINCT order_id) Realcount
FROM dbo.orders;

--check for unique order_status in the order table--
SELECT
DISTINCT order_status
FROM dbo.orders
ORDER BY order_status ASC;

