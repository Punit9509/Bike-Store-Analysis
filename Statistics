--Calculate the Average Selling Price (ASP) for every Brand and compare it with the overall company ASP.
WITH CTE_BrandASP AS
(
SELECT 
B.brand_name,
CAST(SUM((OI.quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) RevenueBybrand,
SUM(OI.Quantity) AS TotalQuantitySold,
CAST(SUM((OI.quantity * OI.list_price) * (1-OI.discount)) / SUM(OI.Quantity) AS DECIMAL (12,2)) ASPbyBrand
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.brands AS B
ON B.brand_id = P.brand_id
GROUP BY 
B.brand_name
),
CTE_OverallCompany_ASP AS
(
SELECT 
Brand_name,
ASPbyBrand,
SUM(RevenueBybrand) OVER() OverallRevenue,
SUM(TotalQuantitySold) OVER() Overallquantity,
CAST(SUM(RevenueBybrand) OVER() / SUM(TotalQuantitySold) OVER() AS DECIMAL (12,2)) AS OverallCompanyASP
FROM CTE_BrandASP 
) 
SELECT 
Brand_name,
ASPbyBrand,
OverallCompanyASP,
CAST(OverallCompanyASP - ASPbyBrand AS DECIMAL (12,2)) AS DifferenceinASP
FROM CTE_OverallCompany_ASP;

