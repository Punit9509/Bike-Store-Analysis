--Show Revenue, Orders, Units Sold and AOV for each Brand.
SELECT 
B.Brand_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) RevenueByBrand,
COUNT(DISTINCT OI.order_id) NumberOforders,
SUM(OI.Quantity) TotalUnitssold,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) / COUNT(DISTINCT OI.order_id) AS DECIMAL (12,2)) AOV
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.brands AS B
ON B.brand_id = P.brand_id
GROUP BY B.Brand_name;

--Rank products within each brand by revenue.
WITH CTE_Revenueby_Brand_Products AS
(
SELECT 
B.brand_name,
P.product_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1 - OI.discount)) AS DECIMAL (12,2)) Revenue
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.Product_id = P.Product_id
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
GROUP BY 
B.brand_name,
P.product_name
)
SELECT 
Brand_name,
Product_name,
Revenue,
DENSE_RANK() OVER(PARTITION BY Brand_name ORDER BY Revenue DESC) Ranking
FROM CTE_Revenueby_Brand_Products;

--Calculate running revenue by Brand and Month.
WITH CTE_RevenueByBrand AS
(
SELECT
B.Brand_name,
DATEPART(YEAR, O.order_date) SaleYear,
DATEPART(MONTH, O.Order_date) Month_Number,
DATENAME(Month, O.order_date) Month_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) RevenueByBrand
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.brands AS B
ON P.Brand_id = B.brand_id
GROUP BY 
B.Brand_name,
DATEPART(YEAR, O.order_date),
DATEPART(MONTH, O.Order_date),
DATENAME(Month, O.order_date)
)
SELECT 
Brand_name,
SaleYear,
Month_name,
RevenueByBrand,
CAST(SUM(RevenueByBrand) OVER(PARTITION BY Brand_name, SaleYear ORDER BY Month_number ASC) AS DECIMAL (12,2)) RunningTotal
FROM CTE_RevenueByBrand;

--Find customers contributing to the first 80% of total revenue.
WITH CTE_Revenuebycustomers AS
(
SELECT 
CONCAT(C.first_name,' ',C.last_name) CustomerName,
CAST(SUM((OI.Quantity * OI.list_Price) * (1 - OI.discount)) AS DECIMAL (12,2)) Revenuebycustomers
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.customers AS C
ON O.customer_id = C.customer_id
GROUP BY C.first_name, C.last_name
),
CTE_RunningRevenue AS
(
SELECT 
CustomerName,
Revenuebycustomers,
SUM(Revenuebycustomers) OVER() OverallRevenue,
CAST(SUM(Revenuebycustomers) OVER(ORDER BY Revenuebycustomers DESC) AS DECIMAL (12,2)) RunningRevenue
FROM CTE_Revenuebycustomers
)
SELECT
Customername,
Revenuebycustomers,
OverallRevenue,
RunningRevenue,
CAST(RunningRevenue * 100 / OverallRevenue AS DECIMAL (12,2)) AS RunningPercentage
FROM CTE_RunningRevenue
WHERE RunningRevenue * 100 / OverallRevenue <= 80
ORDER BY Revenuebycustomers DESC;

--Calculate repeat purchase rate by year.
WITH CTE_CustomerOrders AS 
(
SELECT 
O.customer_id,
YEAR(Order_date) SaleYear,
COUNT(O.order_id) Ordercount
FROM dbo.orders AS O
GROUP BY
O.customer_id,
YEAR(Order_date)
),
CTE_Repeat_Customers AS
(
SELECT 
SaleYear,
COUNT(Customer_id) TotalCustomers,
COUNT(CASE WHEN Ordercount >1 THEN Customer_id END) AS repeatCustomers
FROM CTE_CustomerOrders
GROUP BY SaleYear
)
SELECT 
SaleYear,
Totalcustomers,
repeatCustomers,
repeatcustomers * 100 / Totalcustomers AS Repeatpurchaserate
FROM CTE_Repeat_Customers
ORDER BY Saleyear ASC;

--Create a Product Performance Dashboard showing Revenue, Orders, Units, ASP and Revenue Contribution %.--
WITH CTE_ProductKPI AS
(
SELECT 
P.product_id,
P.Product_name,
CAST(SUM((OI.Quantity * OI.list_price)*(1 - OI.discount)) AS DECIMAL (12,2)) Revenue,
COUNT(OI.order_id) Orders,
SUM(OI.Quantity) Units,
CAST(SUM((OI.Quantity * OI.list_price) * (1 - OI.discount)) / SUM(OI.Quantity) AS DECIMAL (12,2)) ASP
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
GROUP BY 
P.Product_id,
P.Product_name
)
SELECT
Product_id,
Product_name,
Revenue,
orders,
units,
ASP,
SUM(Revenue) OVER() OverallRevenue,
CAST(Revenue * 100 / SUM(Revenue) OVER() AS DECIMAL (12,2)) AS RevenueContributionPercentage
FROM CTE_ProductKPI;

--Create a Brand Performance Dashboard showing Revenue, Orders, Units, Customers and Top Product.
WITH CTE_BrandKPIs AS 
(
SELECT 
B.Brand_id,
B.brand_name,
CAST(SUM((OI.Quantity * OI.list_price) * ( 1 - OI.discount)) AS DECIMAL (12,2)) RevenuebyBrand,
COUNT(DISTINCT OI.order_id) Ordersbybrand,
SUM(OI.Quantity) Unitssoldbybrand,
COUNT(DISTINCT O.customer_id) CustomerCount
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.products AS P
ON P.product_id = OI.product_id
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
GROUP BY
B.Brand_id,
B.brand_name
),
CTE_ProductRevenue AS
(
SELECT 
B.Brand_id,
P.Product_id,
P.Product_name,
CAST(SUM((OI.Quantity * OI.list_price) * ( 1 - OI.discount)) AS DECIMAL (12,2)) Product_Revenue
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
GROUP BY 
B.Brand_id,
P.Product_id,
P.Product_name
),
CTE_Product_Ranking AS
(
SELECT 
CBK.Brand_Name,
CBK.RevenuebyBrand,
CBK.ordersbybrand,
CBK.Unitssoldbybrand,
CBK.CustomerCount,
CPR.Product_name,
CPR.Product_Revenue,
DENSE_Rank() OVER(PARTITION BY CBK.brand_name ORDER BY CPR.Product_Revenue DESC) Product_Ranking
FROM CTE_BrandKPIs AS CBK
JOIN CTE_ProductRevenue AS CPR
ON CBK.Brand_id = CPR.Brand_id
)
SELECT 
Brand_Name,
RevenuebyBrand,
ordersbybrand,
Unitssoldbybrand,
CustomerCount,
Product_name,
Product_Revenue
FROM CTE_Product_Ranking
WHERE Product_Ranking = 1;

--Create a SQL View for Store Revenue and explain when a View is useful.
CREATE VIEW View_Store_Revenue AS
