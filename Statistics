SELECT 
Brand_name,
ASPbyBrand,
SUM(RevenueBybrand) OVER() OverallRevenue,
SUM(TotalQuantitySold) OVER() Overallquantity,
CAST(SUM(RevenueBybrand) OVER() / SUM(TotalQuantitySold) OVER() AS DECIMAL (12,2)) AS OverallCompanyASP
FROM CTE_BrandASP 
) 
SELECT 
Brand_name,
ASPbyBrand,
OverallCompanyASP,
CAST(OverallCompanyASP - ASPbyBrand AS DECIMAL (12,2)) AS DifferenceinASP
FROM CTE_OverallCompany_ASP;

--Find repeat customers and calculate their Customer Lifetime Value (CLV).
SELECT 
O.customer_id,
CONCAT(C.first_name,' ', C.last_name) Customer_name,
COUNT(DISTINCT O.customer_id) NumberOforderPlaced,
SUM(OI.Quantity) NumberOfproductPurchased,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) Revenuebycustomers
FROM dbo.orders AS O
JOIN dbo.order_items AS OI
ON O.Order_id = OI.order_id
JOIN dbo.customers AS C
ON O.customer_id = C.customer_id
GROUP BY 
O.customer_id,
C.first_name,
C.last_name
HAVING COUNT(DISTINCT O.customer_id) > 1
ORDER BY NumberOforderPlaced ASC;

--Create a Customer Performance Dashboard showing Revenue, Orders, Units Purchased, AOV and CLV.
SELECT
C.customer_id,
CONCAT(C.first_name,' ', C.last_name) Customer_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1- OI.discount)) AS DECIMAL (12,2)) RevenueBycustomer,
COUNT(DISTINCT OI.order_id) Numberoforders,
SUM(OI.Quantity) UnitsPurchased,
CAST(SUM((OI.Quantity * OI.list_price) * (1- OI.discount)) /COUNT(DISTINCT OI.order_id) AS DECIMAL (12,2)) AS Customer_AOV,
MIN(O.Order_date) AS first_order,
MAX(O.order_date) AS Last_order,
DATEDIFF(DAY, MIN(O.Order_date), MAX(O.order_date)) Customerlifetimedays
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.customers AS C
ON O.customer_id = C.customer_id
GROUP BY
C.customer_id,
C.first_name,
C.last_name;

