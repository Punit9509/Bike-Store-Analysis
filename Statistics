--Create a store performance report showing Revenue, Orders, Units Sold, ASP, AOV and Revenue Contribution %.

WITH CTE_StoreKPI AS
(
SELECT 
S.Store_id,
S.Store_name,
CAST(SUM((OI.Quantity * OI.list_price) * ( 1 - OI.discount)) AS DECIMAL (12,2)) Revenue,
SUM(OI.Quantity) TotalUnitsSold,
COUNT(DISTINCT OI.order_id) NumberOforders
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.stores AS S
ON S.store_id = O.store_id
GROUP BY 
S.store_id,
S.store_name
)
SELECT 
Store_name,
Revenue,
TotalUnitssold,
NumberOforders,
SUM(Revenue) OVER() OverallRevenue,
CAST(Revenue / Totalunitssold AS DECIMAL (12,2)) AS ASP,
CAST(Revenue / Numberoforders AS DECIMAL (12,2)) AS AOV,
CAST((Revenue/SUM(Revenue) OVER())*100 AS DECIMAL (12,2)) AS RevenueContribution
FROM CTE_StoreKPI;

