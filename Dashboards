--Create a Store Performance Dashboard showing Revenue, Orders, Units, AOV and Top Category.

WITH CTE_StoreKPI AS
(
SELECT 
S.Store_id,
S.Store_name,
CAST(SUM((OI.Quantity * OI.list_price) * ( 1 - OI.discount)) AS DECIMAL (12,2)) RevenuebyStore,
COUNT(DISTINCT OI.order_id) Totalordersbystore,
SUM(OI.Quantity) TotalunitsbyStore,
CAST(SUM((OI.Quantity * OI.list_price) * ( 1 - OI.discount)) / COUNT(DISTINCT OI.order_id) AS DECIMAL (12,2)) AOVbystore
FROM dbo.order_items AS OI
JOIN dbo.orders AS O 
ON OI.order_id = O.order_id
JOIN dbo.stores AS S
ON O.store_id = S.store_id
GROUP BY 
S.Store_id,
S.Store_name
),
CTE_TopCategories AS
(
SELECT
C.Category_id,
S.Store_id,
C.Category_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) RevenuebyCategory
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.stores AS S
ON O.store_id = S.store_id
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.categories AS C
ON P.category_id = C.category_id
GROUP BY 
C.Category_id,
S.Store_id,
C.Category_name
),
CTE_CategoryRanking AS
(
SELECT 
CSK.Store_name,
CSK.Revenuebystore,
CSK.Totalordersbystore,
CSK.Totalunitsbystore,
CSK.AOVbystore,
CTC.Category_name,
CTC.RevenuebyCategory,
DENSE_RANK() OVER(PARTITION BY CSK.Store_name ORDER BY CTC.RevenuebyCategory DESC) Category_Ranking
FROM CTE_StoreKPI AS CSK
JOIN CTE_TopCategories AS CTC
ON CSK.Store_id = CTC.Store_id
)
SELECT 
Store_name,
Revenuebystore,
Totalordersbystore,
Totalunitsbystore,
AOVbystore,
Category_name,
RevenuebyCategory
FROM CTE_CategoryRanking
WHERE Category_Ranking = 1;

--Build a Salesperson Performance Dashboard with Revenue, Orders, Customers and Best Selling Product.
WITH CTE_RevenuebySalesperson AS
(
SELECT 
S.Staff_id,
CONCAT(S.first_name,' ', S.last_name) Staffname,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) Revenuebysalesperson,
COUNT(DISTINCT OI.Order_id) TotalOrders,
COUNT(DISTINCT O.Customer_id) NumberOfcustomerhandledbysalesperson
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.staffs AS S
ON O.staff_id = S.staff_id
JOIN dbo.products AS P
ON OI.product_id = P.product_id
GROUP BY 
S.Staff_id,
S.first_name,
S.last_name
),
CTE_ProductRevenue AS
(
SELECT 
S.Staff_id,
P.Product_id,
P.Product_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) Revenuebyproduct
FROM dbo.order_items AS OI
JOIN dbo.orders AS O
ON OI.order_id = O.order_id
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.staffs AS S
ON O.staff_id = S.staff_id
GROUP BY 
P.Product_id,
P.Product_name,
S.staff_id
),
CTE_Product_Ranking AS
(
SELECT 
CRS.Staffname,
CRS.Revenuebysalesperson,
CRS.TotalOrders,
CRS.Numberofcustomerhandledbysalesperson,
CPR.Product_name,
CPR.Revenuebyproduct,
DENSE_RANK() OVER(PARTITION BY CRS.Staff_id ORDER BY CPR.Revenuebyproduct DESC) Product_Ranking
FROM CTE_RevenuebySalesperson AS CRS
JOIN CTE_ProductRevenue AS CPR
ON CRS.Staff_id = CPR.Staff_id
)
SELECT 
Staffname AS SalespersonName,
RevenueBysalesperson,
TotalOrders,
Numberofcustomerhandledbysalesperson,
Product_name,
Revenuebyproduct
FROM CTE_Product_Ranking
WHERE Product_Ranking = 1
ORDER BY Revenuebyproduct DESC;

--Build a Category Performance Dashboard showing Revenue, Orders, Units, ASP and Revenue Contribution %.
WITH CTE_Category AS
(
SELECT
C.Category_id,
C.Category_name,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) AS DECIMAL (12,2)) CategoryRevenue,
COUNT(DISTINCT OI.order_id) NumberOforders,
SUM(OI.Quantity) Totalunits,
CAST(SUM((OI.Quantity * OI.list_price) * (1-OI.discount)) / SUM(OI.Quantity) AS DECIMAL (12,2)) ASP
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.categories AS C
ON P.Category_id = C.category_id
GROUP BY 
C.Category_id,
C.Category_name
)
SELECT 
Category_id,
Category_Name,
NumberOfOrders,
Totalunits,
ASP,
CategoryRevenue,
SUM(CategoryRevenue) OVER() OverallRevenue,
CAST(CategoryRevenue * 100.0 / SUM(CategoryRevenue) OVER() AS DECIMAL (12,2)) AS RevenueContributionPercentage
FROM CTE_Category
ORDER BY CategoryRevenue DESC;
