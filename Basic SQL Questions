--Prepare a brand performance report with revenue, units, AOV and ranking.
WITH CTE_brandsummary AS
(
SELECT 
B.brand_name,
CAST(SUM((OI.quantity * OI.list_price) * (1 - OI.discount)) AS DECIMAL (12,2)) Revenue,
SUM(OI.quantity) Totalunits,
CAST(SUM((OI.quantity * OI.list_price) * (1 - OI.discount))/SUM(OI.quantity) AS DECIMAL (12,2)) AS AOV
FROM dbo.order_items AS OI
JOIN dbo.products AS P
ON OI.product_id = P.product_id
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
GROUP BY B.brand_name
)
SELECT
Brand_Name,
Revenue,
Totalunits,
AOV,
DENSE_RANK() OVER(ORDER BY Revenue DESC) Revenuewiseranking
FROM CTE_brandsummary;






















































