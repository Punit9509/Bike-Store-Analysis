--Find the top 3 products in each category by revenue.
WITH CTE_Revenue AS
(
SELECT
P.Product_name,
C.Category_name,
CAST(SUM((OI.quantity * OI.list_price) * (1 - OI.discount)) AS DECIMAL (12,2)) Revenue
FROM dbo.Products AS P
