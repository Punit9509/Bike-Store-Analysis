C.customer_id,
C.first_name,
C.last_name;

--Calculate monthly revenue--
SELECT 
DATEPART(MONTH, O.order_date) AS Months,
DATENAME(Month, O.order_date) AS Month_name,
CAST(SUM(OI.quantity * OI.list_price) AS DECIMAL (12,2)) AS Totalrevenue,
CAST(SUM((OI.quantity * OI.list_price) - (1-OI.discount)) AS DECIMAL (12,2)) Revenueafterdiscount
FROM dbo.orders AS O
JOIN dbo.order_items AS OI
ON O.order_id = OI.order_id
GROUP BY DATEPART(MONTH, O.order_date), DATENAME(Month, O.order_date)
Order BY Months ASC;

--Calculate yearly revenue.
SELECT 
DATEPART(Year, o.order_date) AS OrderYear,
CAST(SUM((OI.quantity * OI.list_price) - (1-OI.discount)) AS DECIMAL (12,2)) Revenue
FROM dbo.orders AS O
JOIN dbo.order_items AS OI
ON O.order_id = OI.order_id
GROUP BY DATEPART(Year, o.order_date);

--Find the busiest month based on number of orders.
SELECT TOP 1
DATEPART(Month, order_date) AS Months,
DATENAME(Month, order_date) AS Month_name,
COUNT(order_id) Numberoforders
FROM dbo.orders 
GROUP BY 
DATEPART(Month, order_date),
DATENAME(Month, order_date)
ORDER BY Numberoforders DESC;

--Rank products based on total revenue.
WITH CTE_TotalRevenue AS 
(
SELECT 
P.product_name,
CAST(SUM((OI.quantity * OI.list_price) - (1-OI.discount)) AS DECIMAL (12,2)) TotalRevenue
FROM dbo.products AS P
JOIN dbo.order_items AS OI
ON P.product_id = OI.product_id
GROUP BY P.product_name
)
SELECT 
Product_name,
TotalRevenue,
DENSE_RANK() OVER(ORDER BY TotalRevenue DESC) AS RankRevenue
FROM CTE_TotalRevenue;

--Rank customers based on total spending.
WITH CTE_Totalspendings AS
(
SELECT 
C.Customer_id,
CONCAT(C.first_name,' ',C.last_name) Customername,
CAST(SUM((OI.quantity * OI.list_price) - (1 - OI.discount)) AS DECIMAL (12,2)) TotalSpendings
FROM customers AS C
JOIN orders AS O
ON C.customer_id = O.customer_id
JOIN order_items AS OI
ON O.order_id = OI.order_id
GROUP BY C.customer_id,c.first_name, c.last_name
)
SELECT 
Customer_id,
Customername,
Totalspendings,
DENSE_RANK() OVER(ORDER BY Totalspendings DESC) Rankcustomers
FROM CTE_Totalspendings;

--Calculate month-over-month revenue growth.
WITH CTE_Revenue AS
(
SELECT 
DATEPART(YEAR, O.order_date) AS Saleyear,
DATEPART(MONTH, O.order_date) AS Month_number,
DATENAME(MONTH, O.order_date) AS Month_name,
CAST(SUM((OI.quantity * OI.list_price) * (1 - OI.discount)) AS DECIMAL (12,2)) Revenue
FROM dbo.orders AS O
JOIN dbo.order_items AS OI
ON O.order_id = OI.order_id
GROUP BY 
DATEPART(YEAR, O.order_date),
DATEPART(MONTH, O.order_date),
DATENAME(MONTH, O.order_date)
)
SELECT 
Saleyear,
Month_number,
Month_name,
Revenue,
LAG(Revenue) OVER(PARTITION BY saleyear ORDER BY Month_number ASC) AS Previousmonthrevenue,
Revenue - LAG(Revenue) OVER(PARTITION BY Saleyear ORDER BY Month_number ASC) AS MOMRevenuegrowth
FROM CTE_Revenue;

--Find products priced above the average list price.
SELECT 
Product_name,
CAST(List_price AS DECIMAL (12,2)) AS Product_price
FROM dbo.products
WHERE list_price > (SELECT AVG(list_price) AS Product_price FROM dbo.products)
ORDER BY Product_price DESC;

--Find repeat customers using a CTE.
With CTE_Numberoforders AS
(
SELECT 
C.customer_id,
CONCAT(C.first_name,' ', C.last_name) CustomerName,
COUNT(O.customer_id) Numberoforders
FROM dbo.customers AS C
JOIN orders AS O
ON C.customer_id = O.customer_id
GROUP BY
C.customer_id,
C.first_name,
C.last_name
)
SELECT
Customer_id,
Customername,
Numberoforders
