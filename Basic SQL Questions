--List all customers who have placed at least one order.
SELECT 
C.customer_id,
CONCAT(C.first_name,' ', C.Last_name) AS Customer_name,
COUNT(O.order_status) Numberoforderplacedbycustomer
FROM dbo.Customers AS C
JOIN dbo.orders AS O 
ON C.customer_id = O.customer_id
GROUP BY 
C.customer_id,
CONCAT(C.first_name,' ', C.Last_name)
ORDER BY C.customer_id ASC;

--Display all products with their brand and category.
SELECT DISTINCT
P.Product_name,
B.Brand_name,
C.Category_name
FROM dbo.products AS P
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
JOIN dbo.categories AS C
ON P.category_id = C.category_id;

--Find the top 10 most expensive products.
SELECT TOP 10
Product_name,
CAST(list_price AS DECIMAL (12,2)) AS Product_price
FROM dbo.products
ORDER BY list_price DESC;

--List all unique customer cities.
SELECT 
City,
COUNT(customer_id) Numberofcustomers
FROM DBO.customers
GROUP BY City;

--Count the total number of orders.
SELECT 
COUNT(DISTINCT order_id) NumberOforders
FROM dbo.orders;

--Show every order with the customer's full name.
SELECT 
CONCAT(C.first_name,' ', C.last_name) Customerfullname,
O.order_id,
O.order_status,
O.required_date,
O.order_date,
O.shipped_date
FROM dbo.customers AS C
JOIN orders AS O
ON C.customer_id = O.customer_id;

--Display every product with its brand name.
SELECT
P.product_name,
B.brand_name
FROM dbo.products AS P
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id;

--Display every product with its category name.
SELECT 
P.product_name,
C.category_name
FROM dbo.products AS P
JOIN dbo.categories AS C
ON P.category_id = C.category_id;

--Find the total orders handled by each staff member.
SELECT 
S.Staff_id,
CONCAT(S.first_name, ' ', S.Last_name) StaffName,
SUM(O.order_id) Totalorders
FROM dbo.staffs AS S
JOIN dbo.orders AS O
ON S.staff_id = o.staff_id
GROUP BY 
S.Staff_id,
S.first_name,
S.last_name
ORDER BY Totalorders DESC

--Calculate total revenue by store.
SELECT 
S.Store_id,
S.store_name,
S.city,
SUM(O.order_id) Totalorders
FROM dbo.stores AS S
JOIN dbo.orders AS O
ON S.store_id = O.store_id
GROUP BY 
S.Store_id,
S.store_name,
S.city
ORDER BY Totalorders DESC;

--Calculate revenue, quantity sold and average selling price by brand
SELECT * FROM order_items
SELECT 
B.brand_name,
CAST(SUM(OI.quantity * OI.list_price) AS DECIMAL (12,2)) AS Totalrevenue,
CAST(SUM((OI.list_price * OI.quantity) - (1 - OI.discount)) AS DECIMAL (12,2)) Revenueafterdiscount,
CAST(AVG(OI.list_price) AS DECIMAL (12,2)) Avgsellingprice
FROM dbo.products AS P
JOIN dbo.brands AS B
ON P.brand_id = B.brand_id
JOIN order_items AS OI
ON P.Product_id = OI.product_id
GROUP BY 
B.brand_name;

